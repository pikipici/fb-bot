[Unit]
Description=FB Bot API Server (FastAPI + Uvicorn)
After=network.target redis-server.service

[Service]
Type=simple
User=ubuntu
Group=ubuntu
WorkingDirectory=/home/ubuntu/fb-bot
Environment=PATH=/home/ubuntu/fb-bot/venv/bin:/usr/local/bin:/usr/bin
EnvironmentFile=/home/ubuntu/fb-bot/.env
ExecStart=/home/ubuntu/fb-bot/venv/bin/uvicorn server.main:app --host 0.0.0.0 --port 8100
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
