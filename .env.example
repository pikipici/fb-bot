# FB Bot Environment Configuration
# Copy to /home/ubuntu/fb-bot/.env and fill in values

# === Facebook Account ===
FB_EMAIL=
FB_PASSWORD=

# === Database ===
DATABASE_URL=sqlite:///bot/data/app.db

# === Redis (Celery broker + cache) ===
REDIS_URL=redis://localhost:6382/0

# === JWT Auth ===
JWT_SECRET_KEY=CHANGE_ME_TO_RANDOM_SECRET
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# === AI Provider (optional, feature-flagged) ===
AI_PROVIDER=openai
AI_MODEL=gpt-4o-mini
OPENAI_API_KEY=
# AI_BASE_URL=http://localhost:11434  # Uncomment for Ollama

# === Celery ===
COLLECT_INTERVAL_SECONDS=1800

# === Server ===
API_HOST=0.0.0.0
API_PORT=8100

# === Telegram Notifications (optional) ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# === Sentry (optional) ===
SENTRY_DSN=
