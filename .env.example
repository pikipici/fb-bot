# Database
DATABASE_URL=sqlite:///bot/data/app.db
# DATABASE_URL=postgresql://user:pass@localhost:5432/fb_bot

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=change-me-to-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Telegram Notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Sentry
SENTRY_DSN=

# AI Draft (optional)
AI_PROVIDER=openai
AI_API_KEY=
AI_MODEL=gpt-4o-mini

# App
APP_ENV=development
LOG_LEVEL=INFO
